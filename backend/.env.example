# Paste your own Gemini key here. Never commit the real .env file.
GEMINI_API_KEY=replace_with_your_gemini_key
# Use a model available in your Google AI Studio account. Change this only if needed.
GEMINI_MODEL=gemini-2.5-flash
PORT=4000
# Comma-separated URLs allowed to call this backend during local development.
CORS_ORIGIN=http://localhost:5173
